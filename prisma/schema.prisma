generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model ReforgerSession {
  id String @id @default(cuid())

  serverId  String
  sessionId String @unique

  missionId   String
  missionName String?

  startedAt DateTime?
  endedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events ReforgerEvent[]
}

model ReforgerEvent {
  id      String @id @default(cuid())
  eventId String @unique

  sessionDbId String
  session     ReforgerSession @relation(fields: [sessionDbId], references: [id], onDelete: Cascade)

  type   String
  taskId String?

  oldState     Int?
  oldStateName String?

  newState     Int?
  newStateName String?

  eventTimestamp DateTime
  rawJson        Json

  createdAt DateTime @default(now())
}
